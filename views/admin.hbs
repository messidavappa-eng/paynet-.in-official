                                        <div style="background:#f8fafc; padding:10px; border-radius:8px;">
                                            <small style="color:#64748b; display:block;">Google/User ID</small>
                                            <strong style="color:#1e293b; display:block; margin-top:2px;">${d.details['Google ID']}</strong>
                                        </div>
                                        <div style="background:#f8fafc; padding:10px; border-radius:8px;">
                                            <small style="color:#64748b; display:block;">Domain</small>
                                            <strong style="color:#1e293b; display:block; margin-top:2px;">${d.details.Domain}</strong>
                                        </div>
                                    </div>
                                    <div style="text-align:center; margin-top:10px;">
                                        <small style="color:#10b981;">✅ Mail Server Verified (MX)</small>
                                    </div>
                                </div>
                            </div>
                        `;
                    }

                    resultBox.innerHTML = html;
                    showToast('Target Identification Successful', 'success');
                } else {
                    resultBox.innerHTML = `
                        <div style="padding:20px; text-align:center; color:#ef4444; background:#fef2f2; border-radius:8px; border:1px solid #fee2e2;">
                            <strong>Search Failed</strong>
                            <p style="margin:5px 0 0 0; font-size:14px;">${res.error}</p>
                        </div>`;
                }
            } catch (err) {
                console.error(err);
                resultBox.innerHTML = `<div style="text-align:center; padding:20px; color:red;">System Error: Interface not responding</div>`;
            }
        }

        // ===== Social & Number Logic =====


        async function searchNumber(e) {
            e.preventDefault();
            const num = document.getElementById('intel-phone').value.trim();
            if (num.length !== 10) return showToast('Invalid Number (10 digits required)', 'error');

            const resultContainer = document.getElementById('number-results');
            resultContainer.style.display = 'block';
            resultContainer.innerHTML = `
                <div style="text-align:center; padding:40px;">
                    <div class="loader" style="margin:0 auto 15px;"></div>
                    <p>Accessing Telecom Grid...</p>
                    <small style="color:#64748b">Cross-referencing Signal vs HLR vs CNAM</small>
                </div>
            `;

            try {
                // Fetch basic carrier info
                const response = await fetch('/admin/api/intel/lookup', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ number: num })
                });
                const res = await response.json();

                if (res.success) {
                    const d = res.data;

                    // Generate Deep Links for Tri-Source Name Verification
                    const truecallerLink = `https://www.truecaller.com/search/in/${num}`;
                    const eyeconLink = `https://www.google.com/search?q=site:eyecon-app.com+${num}`; // Fallback to Google index
                    const facebookLink = `https://www.facebook.com/search/people/?q=${num}`;
                    const whatsappLink = `https://api.whatsapp.com/send?phone=91${num}`;
                    const telegramLink = `https://t.me/+91${num}`;

                    resultContainer.innerHTML = `
                        <!-- DETECTED NAME CARD -->
                        <div style="background:linear-gradient(135deg, #1e293b 0%, #0f172a 100%); padding:25px; border-radius:12px; margin-bottom:20px; color:white; text-align:center; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
                            <div style="font-size:11px; opacity:0.75; text-transform:uppercase; letter-spacing:1px; margin-bottom:8px;">Identity Record</div>
                            <div style="font-size:24px; font-weight:700; margin-bottom:5px; color:#38bdf8;">
                                ${d.name || 'Unknown User'} ${d.is_real_name ? '✅' : '🔒'}
                            </div>
                            <div style="font-size:13px; opacity:0.8;">Source: ${d.source || 'Carrier Database'}</div>
                        </div>

                        <div style="background:#f8fafc; padding:20px; border-radius:12px; margin-bottom:20px; border:1px solid #e2e8f0;">
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;">
                                <h3 style="margin:0; font-size:18px;">📲 Signal Intelligence</h3>
                                <span class="badge ${d.valid ? 'badge-success' : 'badge-danger'}">
                                    ${d.valid ? 'Active Line' : 'Inactive'}
                                </span>
                            </div>
                            <div class="stats-grid" style="grid-template-columns: repeat(2, 1fr); gap:15px;">
                                <div>
                                    <small style="color:#64748b; font-size:11px; font-weight:600; text-transform:uppercase;">Carrier Network</small>
                                    <div style="font-weight:600; font-size:15px; color:#0f172a;">${d.carrier}</div>
                                </div>
                                <div>
                                    <small style="color:#64748b; font-size:11px; font-weight:600; text-transform:uppercase;">Circle / Region</small>
                                    <div style="font-weight:600; font-size:15px; color:#0f172a;">${d.circle}</div>
                                </div>
                            </div>
                        </div>

                        <h3 style="font-size:16px; margin-bottom:15px; border-bottom:1px solid #eee; padding-bottom:10px;">
                            🕵️ Tri-Source Identity Resolve
                        </h3>

                        <div class="form-grid">
                            <!-- Source 1: Truecaller -->
                            <a href="${truecallerLink}" target="_blank" class="stat-card" 
                               style="text-decoration:none; color:inherit; border:1px solid #e2e8f0; border-left:4px solid #0087FF; padding:15px;">
                                <div style="display:flex; align-items:center; gap:10px; margin-bottom:5px;">
                                    <span style="font-size:20px;">📞</span>
                                    <div style="font-weight:bold; color:#0087FF;">Source 1: Truecaller</div>
                                </div>
                                <small style="color:#64748b;">Checks Global Spam DB for Name</small>
                            </a>

                            <!-- Source 2: Facebook -->
                            <a href="${facebookLink}" target="_blank" class="stat-card" 
                               style="text-decoration:none; color:inherit; border:1px solid #e2e8f0; border-left:4px solid #1877F2; padding:15px;">
                                <div style="display:flex; align-items:center; gap:10px; margin-bottom:5px;">
                                    <span style="font-size:20px;">📘</span>
                                    <div style="font-weight:bold; color:#1877F2;">Source 2: Facebook</div>
                                </div>
                                <small style="color:#64748b;">Checks for linked profile (Photo/Name)</small>
                            </a>
                            
                            <!-- Source 3: Eyecon (via Google) -->
                            <a href="${eyeconLink}" target="_blank" class="stat-card" 
                               style="text-decoration:none; color:inherit; border:1px solid #e2e8f0; border-left:4px solid #EA4335; padding:15px;">
                                <div style="display:flex; align-items:center; gap:10px; margin-bottom:5px;">
                                    <span style="font-size:20px;">👁️</span>
                                    <div style="font-weight:bold; color:#EA4335;">Source 3: Eyecon</div>
                                </div>
                                <small style="color:#64748b;">Deep Google Search for Eyecon Profile</small>
                            </a>

                            <!-- Instant Messaging Photos -->
                            <a href="${whatsappLink}" target="_blank" class="stat-card" 
                               style="text-decoration:none; color:inherit; border:1px solid #e2e8f0; border-left:4px solid #25D366; padding:15px;">
                                <div style="display:flex; align-items:center; gap:10px; margin-bottom:5px;">
                                    <span style="font-size:20px;">💬</span>
                                    <div style="font-weight:bold; color:#25D366;">WhatsApp Photo</div>
                                </div>
                                <small style="color:#64748b;">Direct Chat Link (Check Profile Pic)</small>
                            </a>
                        </div>
                    `;
                } else {
                    resultContainer.innerHTML = `<div style="padding:20px; text-align:center; color:#ef4444;">❌ Number Analysis Failed. Network busy.</div>`;
                }
            } catch (err) {
                console.error(err);
                resultContainer.innerHTML = `<div style="padding:20px; text-align:center; color:#ef4444;">Offline: Could not connect to intelligence grid.</div>`;
            }
        }
    </script>
</body>

</html>